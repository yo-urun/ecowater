---
// src/components/hybrid/HubSafety.astro
import StatusIcon from './StatusIcon.astro';
---

<section id="safety" class="py-24 lg:py-36 bg-[#F8FAFC]" aria-labelledby="safety-heading">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    
    <!-- Section Header (Mixed V1/V2) -->
    <div class="flex items-start gap-6 mb-16">
      <div class="flex-shrink-0 w-12 h-12 rounded-2xl bg-[#007AFF]/10 flex items-center justify-center mt-1">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="text-[#007AFF]" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <div>
        <div class="inline-flex items-center gap-2 mb-3">
          <span class="font-mono text-xs text-[#007AFF] tracking-[0.15em] uppercase">Hub 01</span>
          <span class="w-8 h-px bg-[#007AFF]/30" />
          <span class="font-mono text-xs text-slate-500 tracking-[0.15em] uppercase">The Protector</span>
        </div>
        <h2 id="safety-heading" class="font-serif text-4xl lg:text-5xl text-slate-900 text-balance mb-3 font-light">
          What Your Tap Water<br />
          <span class="italic text-[#007AFF]">Isn't Telling You</span>
        </h2>
        <p class="text-slate-600 text-lg leading-relaxed max-w-xl">
          Municipal water treatment was designed for 1970s standards. Modern contaminants require modern solutions.
        </p>
      </div>
    </div>

    <!-- Toxins Grid (V1 Content + V2 Layout) -->
    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
      { [
        { name: "PFAS / PFOA", cat: "Forever Chemicals", risk: "Critical", detail: "Linked to cancer, thyroid disruption, and immune suppression. Found in 97% of U.S. water supplies.", color: "text-red-500", bg: "bg-red-50", border: "border-red-200" },
        { name: "Microplastics", cat: "Synthetic Polymers", risk: "High", detail: "Detected in human blood, lungs, and placentas. Over 10,000 particles per liter in tap water.", color: "text-orange-500", bg: "bg-orange-50", border: "border-orange-200" },
        { name: "Heavy Metals", cat: "Lead, Mercury, Arsenic", risk: "Critical", detail: "Neurological damage in children, kidney failure in adults. No safe exposure level exists.", color: "text-red-500", bg: "bg-red-50", border: "border-red-200" },
        { name: "Chlorine & Byproducts", cat: "Disinfectant Residuals", risk: "Moderate", detail: "Forms THMs when reacting with organic matter — known carcinogens accumulating over decades.", color: "text-yellow-600", bg: "bg-yellow-50", border: "border-yellow-200" },
        { name: "Pharmaceutical Traces", cat: "Drug Residuals", risk: "Moderate", detail: "Antibiotics, hormones, and painkillers pass unfiltered through municipal treatment systems.", color: "text-yellow-600", bg: "bg-yellow-50", border: "border-yellow-200" },
        { name: "Nitrates", cat: "Agricultural Runoff", risk: "High", detail: "Cause methemoglobinemia ('blue baby syndrome') and are linked to thyroid cancer in adults.", color: "text-orange-500", bg: "bg-orange-50", border: "border-orange-200" },
      ].map((toxin, i) => (
        <button
          class="toxin-card text-left p-6 rounded-2xl border border-slate-200 bg-white transition-all duration-300 hover:border-[#007AFF]/30 hover:shadow-sm group"
          data-index={i}
        >
          <div class="flex items-start justify-between mb-3">
            <div>
              <div class="text-xs font-mono text-slate-500 uppercase tracking-wider mb-1">{toxin.cat}</div>
              <div class="font-sans font-semibold text-slate-900 text-base">{toxin.name}</div>
            </div>
            <span class={`text-xs font-mono font-bold px-2.5 py-1 rounded-full ${toxin.bg} ${toxin.color} border ${toxin.border}`}>
              {toxin.risk}
            </span>
          </div>
          <div class="toxin-detail overflow-hidden max-h-0 opacity-0 transition-all duration-300">
            <p class="text-sm text-slate-600 leading-relaxed pt-2 border-t border-slate-100">{toxin.detail}</p>
          </div>
          <div class="toxin-hint text-xs text-slate-400 mt-2 font-mono">
            Click to reveal health data
          </div>
        </button>
      ))}
    </div>

    <!-- Comparison Table (V1 Authority + V2 Styling) -->
    <div class="rounded-3xl border border-slate-200 overflow-hidden shadow-sm">
      <div class="bg-[#002B49] text-white px-6 py-5 flex items-center gap-3">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
        </svg>
        <h3 class="font-sans font-semibold text-base tracking-wide">The Definitive Comparison</h3>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full" role="table">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="text-left px-6 py-4 text-sm font-mono font-medium text-slate-500 uppercase tracking-wider w-1/2" scope="col">
                Quality Metric
              </th>
              <th class="px-6 py-4 text-center text-sm font-mono font-medium text-slate-500 uppercase tracking-wider" scope="col">
                Tap Water
              </th>
              <th class="px-6 py-4 text-center text-sm font-mono font-medium text-slate-500 uppercase tracking-wider" scope="col">
                Bottled Water
              </th>
              <th class="px-6 py-4 text-center text-sm font-semibold uppercase tracking-wider text-[#007AFF]" scope="col">
                EcovodaLife
              </th>
            </tr>
          </thead>
          <tbody>
            {[
              { metric: "PFAS Removal", tap: false, bottle: "Partial", eco: true },
              { metric: "Microplastics", tap: false, bottle: false, eco: true },
              { metric: "Heavy Metals", tap: false, bottle: "Partial", eco: true },
              { metric: "Pharmaceutical Residue", tap: false, bottle: false, eco: true },
              { metric: "pH Balanced (7.2–7.8)", tap: false, bottle: "Varies", eco: true },
              { metric: "Mineralized Output", tap: false, bottle: "Varies", eco: true },
              { metric: "Real-time TDS Monitoring", tap: false, bottle: false, eco: true },
              { metric: "Zero Plastic Waste", tap: true, bottle: false, eco: true },
              { metric: "Cost per Liter", tap: "~$0.002", bottle: "~$0.50", eco: "~$0.015" },
            ].map((row, i) => (
              <tr class={`border-b border-slate-100 transition-colors hover:bg-slate-50 ${i % 2 === 0 ? "bg-white" : "bg-slate-50/30"}`}>
                <td class="px-6 py-4 text-sm font-sans text-slate-900">{row.metric}</td>
                <td class="px-6 py-4 text-center"><StatusIcon value={row.tap} /></td>
                <td class="px-6 py-4 text-center"><StatusIcon value={row.bottle} /></td>
                <td class="px-6 py-4 text-center font-medium bg-[#007AFF]/5"><StatusIcon value={row.eco} /></td>
              </tr>
            ))
          }
          </tbody>
        </table>
      </div>
    </div>

    <!-- Certification Trust Bar (V2 style Gradient) -->
    <div class="mt-10 rounded-2xl bg-gradient-to-r from-[#002B49] to-[#005A8C] p-6 lg:p-8 text-white shadow-lg">
      <p class="font-mono text-xs text-white/40 tracking-[0.15em] uppercase mb-6">Certification & Compliance</p>
      <div class="flex flex-wrap gap-4">
        {[
          { cert: "NSF/ANSI 58", body: "National Sanitation Foundation" },
          { cert: "WQA Gold Seal", body: "Water Quality Association" },
          { cert: "EPA Verified", body: "Environmental Protection Agency" },
          { cert: "ISO 9001:2015", body: "International Standards Org." },
        ].map((c) => (
          <div class="flex items-center gap-3 bg-white/10 rounded-xl px-4 py-3 border border-white/15 backdrop-blur-sm">
            <div class="w-4 h-4 rounded-full border-2 border-[#7FB3B3]" aria-hidden="true"></div>
            <div>
              <div class="text-sm font-sans font-semibold text-white">{c.cert}</div>
              <div class="text-xs text-white/40 font-mono">{c.body}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.toxin-card').forEach(card => {
      card.addEventListener('click', () => {
        const detail = card.querySelector('.toxin-detail');
        const hint = card.querySelector('.toxin-hint');
        const isExpanded = detail.classList.contains('max-h-24');
        
        document.querySelectorAll('.toxin-detail').forEach(d => {
          d.classList.remove('max-h-24', 'opacity-100');
          d.classList.add('max-h-0', 'opacity-0');
        });
        document.querySelectorAll('.toxin-hint').forEach(h => h.classList.remove('hidden'));

        if (!isExpanded) {
          detail.classList.remove('max-h-0', 'opacity-0');
          detail.classList.add('max-h-24', 'opacity-100');
          hint.classList.add('hidden');
        }
      });
    });
  });
</script>
