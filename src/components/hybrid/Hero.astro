---
// src/components/hybrid/Hero.astro
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col justify-center overflow-hidden bg-gradient-to-br from-[#002B49] via-[#004A75] to-[#007AFF]"
  aria-label="Hero section"
>
  <!-- Animated canvas overlay for water ripples (from V1) -->
  <canvas
    id="hero-canvas"
    class="absolute inset-0 z-10 w-full h-full pointer-events-none"
    aria-hidden="true"
  ></canvas>

  <!-- Lab-meets-nature visual overlay: subtle grid pattern (from V1) -->
  <div
    class="absolute inset-0 z-10 opacity-5 pointer-events-none"
    style="background-image: linear-gradient(rgba(100,180,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(100,180,255,1) 1px, transparent 1px); background-size: 80px 80px;"
    aria-hidden="true"
  ></div>

  <!-- Organic shape: blended nature orb (from V1) -->
  <div
    class="absolute right-0 top-0 w-1/2 h-full z-10 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 80% at 80% 50%, rgba(127, 179, 179, 0.18) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <!-- Main Content (Mixed V1/V2) -->
  <div class="relative z-20 max-w-7xl mx-auto px-6 lg:px-12 pt-20 pb-12 lg:pt-24 lg:pb-20">
    <div class="max-w-3xl">
      <!-- Pre-headline badge -->
      <div class="inline-flex items-center gap-2.5 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-2 mb-6">
        <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse" aria-hidden="true"></span>
        <span class="text-white/80 text-xs font-mono font-medium tracking-widest uppercase">
          Medical-Grade Certified
        </span>
      </div>

      <!-- Main headline (V2 Typography: light, airy, italic accents) -->
      <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl xl:text-7xl text-white leading-tight text-balance mb-4 font-light">
        Medical-Grade Trust
        <br />
        <span class="italic text-[#7FB3B3]">meets</span>{" "}
        <span class="bg-gradient-to-r from-[#7FB3B3] to-[#AEE0B5] bg-clip-text text-transparent">
          Nature's Purity
        </span>
      </h1>
      <p class="text-white/90 text-sm font-mono uppercase tracking-[0.3em] mb-6 text-center lg:text-left">
        Premium Filtration for Montenegro
      </p>

      <!-- Subheadline (V2 style: sans, light, high readability) -->
      <p class="text-white/70 text-lg lg:text-xl leading-relaxed max-w-xl mb-8 font-sans font-light">
        Premium water filtration that protects your family, optimizes your health, and saves the planet — one drop at a time.
      </p>

      <!-- CTAs (V1 functional, V2 aesthetic) -->
      <div id="hero-cta" class="flex flex-col sm:flex-row gap-4 mb-12">
        <a
          href="#safety"
          class="group inline-flex items-center justify-center gap-3 bg-white text-[#002B49] text-sm font-semibold px-8 py-4 rounded-full hover:bg-white/95 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          Analyze Your Water
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:translate-x-1 transition-transform" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="#technology"
          class="inline-flex items-center justify-center gap-2.5 bg-white/10 text-white text-sm font-medium px-8 py-4 rounded-full border border-white/25 hover:bg-white/20 transition-all duration-300 backdrop-blur-sm"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="2"/><path d="M12 2v4m0 12v4m10-10h-4M6 12H2m14.24-6.36l-2.83 2.83M8.59 15.53l-2.83 2.83m0-14.14l2.83 2.83m5.65 5.65l2.83 2.83"/>
          </svg>
          Explore Technology
        </a>
      </div>

      <!-- Stats row (V1's authority, V2's spacing) -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { value: "99.9%", label: "Contaminant Removal" },
          { value: "500+", label: "Toxins Filtered" },
          { value: "10yr", label: "System Lifespan" },
          { value: "0", label: "Plastic Waste" },
        ].map((stat) => (
          <div class="text-center border-l border-white/15 pl-4 first:border-0 first:pl-0">
            <div class="text-2xl lg:text-3xl font-sans font-bold text-white mb-1">{stat.value}</div>
            <div class="text-white/50 text-xs font-mono uppercase tracking-wider">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Trust bar (V1) -->
  <div class="relative z-20 border-t border-white/10 bg-black/20 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-4">
      <div class="flex flex-wrap items-center justify-center md:justify-between gap-4">
        <span class="text-white/40 text-xs font-mono uppercase tracking-widest hidden md:block">Certified By</span>
        <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10">
          {[
            { label: "NSF/ANSI 58", desc: "RO Certified" },
            { label: "WHO Approved", desc: "Health Standard" },
            { label: "ISO 9001", desc: "Quality Mgmt" },
            { label: "EPA Listed", desc: "PFAS Removal" },
          ].map((cert) => (
            <div class="flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-emerald-400/70" aria-hidden="true"></div>
              <div>
                <div class="text-white/90 text-xs font-mono font-semibold tracking-wider">{cert.label}</div>
                <div class="text-white/40 text-[10px] font-sans uppercase tracking-widest">{cert.desc}</div>
              </div>
            </div>
          ))}
        </div>
        <span class="text-white/40 text-xs font-mono uppercase tracking-widest hidden md:block">Est. 2019</span>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 animate-bounce" aria-hidden="true">
    <div class="w-6 h-9 rounded-full border border-white/20 flex items-start justify-center pt-2">
      <div class="w-1 h-2 rounded-full bg-white/60"></div>
    </div>
  </div>
</section>

<script>
  function initHeroCanvas() {
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let animFrame: number;
    let t = 0;

    const resize = () => {
      canvas.width = canvas.offsetWidth * window.devicePixelRatio;
      canvas.height = canvas.offsetHeight * window.devicePixelRatio;
      ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    };

    resize();
    window.addEventListener('resize', resize);

    const draw = () => {
      const w = canvas.offsetWidth;
      const h = canvas.offsetHeight;
      ctx.clearRect(0, 0, w, h);

      // Animated water ripple rings
      for (let i = 0; i < 5; i++) {
        const phase = (t * 0.3 + i * 0.7) % (Math.PI * 2);
        const radius = 60 + i * 55 + Math.sin(phase) * 15;
        const alpha = 0.04 - i * 0.006;
        ctx.beginPath();
        ctx.arc(w * 0.72, h * 0.45, radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(100, 180, 255, ${alpha})`;
        ctx.lineWidth = 1.5;
        ctx.stroke();
      }

      // Floating particles
      for (let i = 0; i < 20; i++) {
        const x = (Math.sin(t * 0.1 + i * 2.3) * 0.5 + 0.5) * w * 0.6 + w * 0.2;
        const y = (Math.cos(t * 0.08 + i * 1.7) * 0.5 + 0.5) * h * 0.7 + h * 0.1;
        const r = 1.5 + Math.sin(t * 0.2 + i) * 0.8;
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(100, 200, 240, ${0.12 + Math.sin(t * 0.15 + i) * 0.06})`;
        ctx.fill();
      }

      t += 0.02;
      animFrame = requestAnimationFrame(draw);
    };

    draw();
  }

  // Handle Astro view transitions if used
  document.addEventListener('astro:page-load', initHeroCanvas);
  // Initial load
  initHeroCanvas();
</script>
