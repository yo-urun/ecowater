---
/**
 * Hero Component - v0 Style
 * High-conversion header for EcovodaLife.
 * 
 * Props:
 * - title: Main headline (string)
 * - subtitle: Descriptive subtext (string)
 * - ctaText: Label for the primary button (string)
 * - ctaLink: URL for the primary button (string)
 * - secondaryCtaText: Label for the secondary button (optional)
 * - secondaryCtaLink: URL for the secondary button (optional)
 * - align: 'center' | 'left' | 'right' (default: 'center')
 */

interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  align?: 'center' | 'left' | 'right';
}

const { 
  title, 
  subtitle, 
  ctaText, 
  ctaLink, 
  secondaryCtaText, 
  secondaryCtaLink, 
  align = 'center' 
} = Astro.props;

const alignmentClasses = {
  center: 'text-center items-center',
  left: 'text-left items-start',
  right: 'text-right items-end',
};
---

<section class={`relative overflow-hidden py-20 lg:py-32 flex flex-col ${alignmentClasses[align]} ${align === 'center' ? 'mx-auto' : ''} max-w-7xl px-6`}>
  <!-- Subtle background element for v0 depth -->
  <div class="absolute -top-24 -left-24 w-96 h-96 bg-blue-50 rounded-full blur-3xl opacity-50 -z-10"></div>
  <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-slate-50 rounded-full blur-3xl opacity-50 -z-10"></div>

  <div class="relative z-10 max-w-4xl">
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-slate-900 leading-tight mb-6">
      {title}
    </h1>
    
    <p class="text-lg md:text-xl text-slate-600 leading-relaxed mb-10 max-w-2xl {align === 'center' ? 'mx-auto' : ''}">
      {subtitle}
    </p>
    
    <div class={`flex flex-wrap gap-4 ${align === 'center' ? 'justify-center' : align === 'right' ? 'justify-end' : 'justify-start'}`}>
      <a 
        href={ctaLink} 
        class="px-8 py-4 bg-slate-900 text-white font-medium rounded-full hover:bg-slate-800 transition-all duration-200 shadow-sm hover:shadow-md active:scale-95"
      >
        {ctaText}
      </a>
      
      {secondaryCtaText && secondaryCtaLink && (
        <a 
          href={secondaryCtaLink} 
          class="px-8 py-4 bg-white text-slate-900 font-medium rounded-full border border-slate-200 hover:bg-slate-50 transition-all duration-200 active:scale-95"
        >
          {secondaryCtaText}
        </a>
      )}
    </div>
  </div>
</section>
