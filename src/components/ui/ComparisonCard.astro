---
/**
 * ComparisonCard Component - v0 Style
 * Clean card for comparing water filter products.
 * 
 * Props:
 * - name: Product name (string)
 * - price: Formatted price (string)
 * - rating: Rating score (string, e.g., "4.8/5")
 * - imageSrc: URL to product image (string)
 * - features: Array of key features (string[])
 * - pros: Array of pros (string[])
 * - cons: Array of cons (string[])
 * - badge: Optional badge text (e.g., "Best Value")
 * - ctaLink: URL to product page or affiliate link (string)
 */

interface Props {
  name: string;
  price: string;
  rating: string;
  imageSrc: string;
  features: string[];
  pros: string[];
  cons: string[];
  badge?: string;
  ctaLink: string;
}

const { name, price, rating, imageSrc, features, pros, cons, badge, ctaLink } = Astro.props;
---

<div class="group relative bg-white border border-slate-200 rounded-3xl p-6 transition-all duration-300 hover:border-slate-300 hover:shadow-lg hover:shadow-slate-100 flex flex-col h-full">
  {badge && (
    <div class="absolute -top-3 left-6 px-3 py-1 bg-slate-900 text-white text-xs font-bold rounded-full uppercase tracking-wider">
      {badge}
    </div>
  )}

  <div class="flex flex-col md:flex-row gap-8 mb-8">
    <div class="w-full md:w-48 h-48 bg-slate-50 rounded-2xl overflow-hidden flex items-center justify-center p-4 transition-transform duration-300 group-hover:scale-105">
      <img src={imageSrc} alt={name} class="max-w-full max-h-full object-contain" />
    </div>
    
    <div class="flex-1">
      <div class="flex justify-between items-start mb-2">
        <h3 class="text-xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors">
          {name}
        </h3>
        <span class="text-lg font-semibold text-slate-900">{price}</span>
      </div>
      
      <div class="flex items-center gap-2 mb-4">
        <div class="flex text-yellow-400">
          <!-- Simple star representation -->
          <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
        </div>
        <span class="text-sm text-slate-500 font-medium">{rating}</span>
      </div>

      <ul class="space-y-2">
        {features.map(feature => (
          <li class="text-sm text-slate-600 flex items-center">
            <span class="mr-2 text-slate-300">✓</span> {feature}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="space-y-2">
      <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Pros</h4>
      <ul class="space-y-1">
        {pros.map(pro => (
          <li class="text-sm text-slate-700 flex items-start">
            <span class="mr-2 text-green-500 font-bold">+</span> {pro}
          </li>
        ))}
      </ul>
    </div>
    <div class="space-y-2">
      <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest">Cons</h4>
      <ul class="space-y-1">
        {cons.map(con => (
          <li class="text-sm text-slate-700 flex items-start">
            <span class="mr-2 text-red-400 font-bold">−</span> {con}
          </li>
        ))}
      </ul>
    </div>
  </div>

  <a 
    href={ctaLink} 
    class="mt-auto w-full block text-center py-3 px-6 bg-slate-100 text-slate-900 font-semibold rounded-xl hover:bg-slate-900 hover:text-white transition-all duration-200 active:scale-95"
  >
    View Details
  </a>
</div>
